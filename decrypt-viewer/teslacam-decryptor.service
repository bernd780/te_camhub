[Unit]
Description=Te_FITI-derived local decryptor + viewer for teslausb
After=network-online.target teslacam-latest-snapshot.service
Requires=teslacam-latest-snapshot.service

[Service]
Type=simple
Environment=DATA_DIR=/backingfiles/decrypt-viewer-state
# OUT_DIR is on tmpfs (/dev/shm) so decrypted plaintext lives only in RAM and
# never touches the stick; it is wiped on every reboot.
ExecStartPre=/bin/mkdir -p /backingfiles/decrypt-viewer-state /dev/shm/teslacam
ExecStart=/usr/bin/python3 /opt/teslacam-decryptor/app/server.py \
  --scan /run/teslacam-latest/mnt/TeslaCam \
  --src /run/teslacam-latest/mnt/TeslaCam/EncryptedClips \
  --out /dev/shm/teslacam \
  --port 8099 \
  --interval 60
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
